{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "--project-root",
        "."
      ],
      "env": {}
    }
  },
  "memoryConfig": {
    "provider": "serena",
    "basePath": ".serena/memories",
    "tools": {
      "read": "read_memory",
      "write": "write_memory",
      "edit": "edit_memory",
      "list": "list_memories",
      "delete": "delete_memory"
    }
  },
  "toolGroups": {
    "memory": [
      "read_memory",
      "write_memory",
      "edit_memory",
      "list_memories",
      "delete_memory"
    ],
    "code-analysis": [
      "get_symbols_overview",
      "find_symbol",
      "find_referencing_symbols",
      "search_for_pattern"
    ],
    "project": [
      "activate_project",
      "get_current_config",
      "onboarding"
    ],
    "thinking": [
      "think_about_collected_information",
      "think_about_task_adherence",
      "think_about_whether_you_are_done"
    ]
  }
}
